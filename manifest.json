{
  "manifest_version": 3,
  "name": "n0t381x - Operational Filter",
  "version": "2.0",
  "description": "Filters academic text into operational security notes using DeepSeek.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.hackthebox.com/*",
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "note81x@local.internal"
    }
  }
}
